# ============================================
# CV Review Bot - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED - Manager Must Configure These
# ============================================

# Telegram Bot Token from BotFather
# How to get: 
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot command
# 3. Choose a name for your bot
# 4. Choose a username (must end with 'bot')
# 5. Copy the token provided
BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API Key for LLM Access
# How to get:
# 1. Go to https://openrouter.ai/
# 2. Sign up for an account
# 3. Go to API Keys section
# 4. Create a new API key
# 5. Copy the key here
OPENROUTER_KEY=your_openrouter_api_key_here

# ============================================
# OPTIONAL - Developer Configuration
# These have defaults but can be customized
# ============================================

# Manager Telegram IDs (comma-separated)
# How to get your Telegram ID:
# 1. Send message to @userinfobot
# 2. It will reply with your ID
# Example: MANAGER_IDS=123456789,987654321
MANAGER_IDS=

# Database Configuration
# DATABASE_PATH=./data/reviews.db

# Repository Processing Limits
# MAX_REPO_SIZE_MB=100
# CLONE_TIMEOUT=60

# Analysis Configuration
# ANALYSIS_TIMEOUT=600
# MAX_CONCURRENT=3

# LLM Model Selection
# PRIMARY_MODEL=google/gemini-2.0-flash-exp
# FALLBACK_MODEL=openai/gpt-4o-mini
# MAX_TOKENS=900000
# TEMPERATURE=0.2

# Temporary Directory for Cloning
# TEMP_DIR=/tmp/repos

# Cache Duration (seconds)
# CACHE_DURATION=3600