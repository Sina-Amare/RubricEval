# ============================================================
# Rubric Evaluation Platform — environment configuration
# Copy to .env and fill in. Used by docker-compose and local runs.
# ============================================================

# --- Operator auth (CHANGE THESE) ---------------------------
# Shared token that gates the web panel + API.
OPERATOR_TOKEN=change-me-operator-token
# Secret used to derive the BYOK key-encryption key. Use 32+ random chars.
APP_SECRET_KEY=change-me-please-32-chars-minimum-secret

# --- LLM (BYOK) ---------------------------------------------
# Your OpenRouter key. ROTATE the one shared in chat before using.
OPENROUTER_API_KEY=
DEFAULT_MODEL=openrouter/openai/gpt-oss-120b:free
# "litellm" for real calls, "fake" for deterministic offline runs/tests.
LLM_BACKEND=litellm
LLM_CONCURRENCY=1

# --- Database -----------------------------------------------
# No-Docker default (SQLite, zero-config):
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# Docker (Postgres) — compose overrides this automatically:
# DATABASE_URL=postgresql+asyncpg://rubric:rubric@postgres:5432/rubric
AUTO_MIGRATE=true
EMBEDDED_WORKER=true

# --- Frontend -----------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
