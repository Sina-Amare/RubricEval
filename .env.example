# ============================================================
# RubricEval — environment configuration
# Copy to .env and fill in. Used by docker-compose and local runs.
# Secrets live ONLY in this git-ignored .env — never commit them.
# ============================================================

# --- Operator auth (CHANGE THESE) ---------------------------
# Token that gates the web panel + API. Sign in with it in the UI.
OPERATOR_TOKEN=change-me-operator-token
# Secret used to derive the BYOK key-encryption key. Use 32+ random chars.
APP_SECRET_KEY=change-me-please-32-chars-minimum-secret

# --- LLM (BYOK, provider-agnostic via LiteLLM) --------------
# "litellm" for real calls, "fake" for deterministic offline runs/tests.
LLM_BACKEND=litellm
# The provider is inferred from the model-id prefix, so you only set the
# keys for the providers you actually use. Default tried first, then each
# comma-separated FALLBACK_MODEL on rate-limit/outage.
DEFAULT_MODEL=openrouter/openai/gpt-oss-120b:free
FALLBACK_MODEL=gemini/gemini-flash-latest
# Keys (comma-separated within one var = rotated across calls on rate-limit).
OPENROUTER_API_KEY=        # https://openrouter.ai/keys  — for openrouter/* models
GOOGLE_API_KEY=            # https://aistudio.google.com/apikey — for gemini/* models
GROQ_API_KEY=              # https://console.groq.com/keys — for groq/* models
LLM_CONCURRENCY=1

# --- Database -----------------------------------------------
# No-Docker default (SQLite, zero-config):
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# Docker (Postgres) — compose overrides this automatically:
# DATABASE_URL=postgresql+asyncpg://rubric:rubric@postgres:5432/rubric
AUTO_MIGRATE=true
EMBEDDED_WORKER=true

# --- Frontend -----------------------------------------------
# Where the browser reaches the API (inlined into the web build).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
